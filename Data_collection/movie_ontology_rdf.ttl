    :hasGenre :Adventure ;
    :hasGenre :Fantasy ;
    :hasGenre :Family ;
    :directedBy :Chris_Columbus ;
    :producedBy :1492_Pictures ;
    :producedBy :Warner_Bros ;
    :producedBy :Heyday_Films ;
    :producedIn :United_Kingdom ;
    :producedIn :United_States_of_America ;.

